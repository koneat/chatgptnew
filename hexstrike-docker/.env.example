# =========================
# HexStrike Docker 基础配置
# =========================

# 上游源码位置和分支/tag
HEXSTRIKE_REPO=https://github.com/0x4m4/hexstrike-ai.git
HEXSTRIKE_REF=master

# API 监听配置
HEXSTRIKE_HOST=0.0.0.0
HEXSTRIKE_PORT=8888

# 默认只绑定本机；Cloudflare Tunnel 转发本机即可。
# 如必须局域网/公网访问，改为 0.0.0.0，但必须设置强 API Key。
HEXSTRIKE_BIND=127.0.0.1

# Docker 层 API Key 保护
# 建议：openssl rand -hex 32
HEXSTRIKE_API_KEY=change_me_to_a_long_random_value
HEXSTRIKE_API_KEY_HEADER=X-HexStrike-Api-Key
HEXSTRIKE_API_KEY_ALLOW_HEALTH=true

# 安装补充工具，第一次构建慢；想快速构建可改 false
INSTALL_GO_TOOLS=true
INSTALL_PY_TOOLS=true

# 浏览器自动化
CHROME_BIN=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver
DISPLAY=:99

# 命令执行和缓存
HEXSTRIKE_COMMAND_TIMEOUT=900
HEXSTRIKE_CACHE_SIZE=1000
HEXSTRIKE_CACHE_TTL=3600

# =========================
# 第三方情报 / OSINT API Key
# 不要把真实值提交到 GitHub
# =========================

SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
SECURITYTRAILS_API_KEY=
CHAOS_KEY=
GITHUB_TOKEN=
GITLAB_TOKEN=

# 国内常用情报平台
FOFA_EMAIL=
FOFA_KEY=
HUNTER_API_KEY=
QUAKE_TOKEN=
ZOOMEYE_API_KEY=

# 云安全 / 容器安全
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# 代理，可选
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,hexstrike
