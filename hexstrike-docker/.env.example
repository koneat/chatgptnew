# HexStrike Docker rebuilt config
# Do not put real secrets in GitHub.

# Docker host binding. Keep this local.
HEXSTRIKE_BIND=127.0.0.1
HEXSTRIKE_HOST_PORT=8888

# Upstream source used during Docker build.
HEXSTRIKE_REPO=https://github.com/0x4m4/hexstrike-ai.git
HEXSTRIKE_REF=master

# Optional: faster first build when false.
INSTALL_EXTRA_TOOLS=true

# MCP runs on the physical host and connects to this API.
HEXSTRIKE_SERVER=http://127.0.0.1:8888

# Optional third-party keys. Leave blank unless needed.
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
SECURITYTRAILS_API_KEY=
GITHUB_TOKEN=
GITLAB_TOKEN=
FOFA_EMAIL=
FOFA_KEY=
HUNTER_API_KEY=
QUAKE_TOKEN=
ZOOMEYE_API_KEY=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost
